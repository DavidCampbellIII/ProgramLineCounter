[
    {
        "name": "C-Sharp",
        "extensions": ".cs",
        "comment": "//",
        "multiLineComments": {
            "start": "/*",
            "end": "*/"
        },
        "canHaveMultiLines": true,
        "lineEnder": ";",
        "lineBreaker": ""
    },
    {
        "name": "Python",
        "extensions": ".py",
        "comment": "#",
        "multiLineComments": {
            "start": "''' | \"\"\"",
            "end": "''' | \"\"\""
        },
        "canHaveMultiLines": false,
        "lineEnder": "",
        "lineBreaker": "\\"
    },
    {
        "name": "Java",
        "extensions": ".java",
        "comment": "//",
        "multiLineComments": {
            "start": "/*",
            "end": "*/"
        },
        "canHaveMultiLines": true,
        "lineEnder": ";",
        "lineBreaker": ""
    },
    {
        "name": "C++",
        "extensions": [".cpp", ".h"],
        "comment": "//",
        "multiLineComments": {
            "start": "/*",
            "end": "*/"
        },
        "canHaveMultiLines": true,
        "lineEnder": ";",
        "lineBreaker": ""
    }
]